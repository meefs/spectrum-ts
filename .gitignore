# dependencies (bun install)
node_modules

# output
out
dist
*.tgz

# local scratch work (ad-hoc scripts, debugging, real-account experiments)
tmp

# copied from repo root at build/release time so they ship with the npm
# package (clean-publish strips all scripts from the staged package.json, so
# prepack/prepublish hooks never run). The runtime's README is a copy of the
# repo root's; every other package commits its own.
packages/core/README.md
packages/*/LICENSE

# clean-publish staging dirs (check-artifacts, preview workflow)
.clean-publish-tmp
.preview

# code coverage
coverage
*.lcov

# logs
logs
_.log
report.[0-9]_.[0-9]_.[0-9]_.[0-9]_.json

# dotenv environment variable files
.env
.env.development.local
.env.test.local
.env.production.local
.env.local

# Turborepo
.turbo

# caches
.eslintcache
.cache
*.tsbuildinfo

