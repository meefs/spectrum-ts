{
  "name": "@spectrum-ts/whatsapp-business",
  "version": "9.0.0",
  "description": "WhatsApp Business provider for spectrum-ts.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/photon-hq/spectrum-ts.git",
    "directory": "packages/whatsapp-business"
  },
  "homepage": "https://photon.codes/spectrum",
  "bugs": {
    "url": "https://github.com/photon-hq/spectrum-ts/issues"
  },
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "bun": "./src/index.ts",
      "types": "./src/index.ts",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "spectrum": {
    "key": "whatsapp-business",
    "import": "whatsappBusiness",
    "label": "WhatsApp Business"
  },
  "scripts": {
    "build": "tsdown && node ../../scripts/smoke-import.mjs dist/index.js",
    "dev": "tsdown --watch",
    "test:bun": "bun --bun vitest run",
    "test:node": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@photon-ai/whatsapp-business": "^0.2.0",
    "mime-types": "^3.0.1",
    "zod": "^4.2.1"
  },
  "peerDependencies": {
    "@spectrum-ts/core": "^9.0.0",
    "typescript": "^5 || ^6.0.0"
  },
  "devDependencies": {
    "@spectrum-ts/core": "workspace:*",
    "@spectrum-ts/test-support": "workspace:*",
    "@types/bun": "latest",
    "@types/mime-types": "^3.0.1",
    "tsdown": "^0.22.2",
    "vitest": "^4.1.9"
  },
  "license": "MIT"
}
